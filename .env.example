# ─── App ───────────────────────────────────────────────
NODE_ENV=development
PORT=5000
API_VERSION=v1

# ─── Database ──────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/job-hunt-ai
MONGODB_URI_PROD=mongodb+srv://<user>:<password>@cluster.mongodb.net/job-hunt-ai

# ─── Auth (Clerk) ──────────────────────────────────────
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# ─── AI (Google Gemini) ────────────────────────────────
# Get your free API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxx

# ─── CORS ──────────────────────────────────────────────
CLIENT_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Rate Limiting ─────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Logging ───────────────────────────────────────────
LOG_LEVEL=debug
LOG_DIR=logs
